APP_NAME=tfstate-drift-inspector
APP_ENV=production
APP_PORT=8080
APP_HOST=0.0.0.0

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/drift_inspector

# GitHub App
GITHUB_APP_ID=0123456
GITHUB_APP_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END RSA PRIVATE KEY-----\nGITHUB_CLIENT_ID=your_client_id
GITHUB_CLIENT_SECRET=your_client_secret
GITHUB_WEBHOOK_SECRET=your_webhook_secret

# Slack
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your_signing_secret
SLACK_DEFAULT_CHANNEL=#devops-alerts

# Terraform
TERRAFORM_PATH=terraform
TERRAFORM_WORKING_DIR=/tmp/tf-drift-workspaces

# Cron
SCAN_CRON=0 2 * * *

# Stripe (for SaaS billing)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_ID_MONTHLY=price_xxx
STRIPE_PRICE_ID_YEARLY=price_xxx

# Logging
LOG_LEVEL=INFO

# Alert emails (comma-separated)
SENDGRID_API_KEY=SG.xxx
ALERT_FROM_EMAIL=drift@yourdomain.com
ALERT_TO_EMAILS=ops@yourdomain.com,devops@yourdomain.com